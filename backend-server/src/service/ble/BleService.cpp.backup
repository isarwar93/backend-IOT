{
    try {
        auto json = nlohmann::json::parse(body);
        std::string mac = json.value("mac", "");
        if (!m_deviceManager) return false;
        return m_deviceManager->isConnected(mac);
    } catch (const std::exception& e) {
        LOGE("Is connected error: {}", e.what());
        return false;
    }
