#ifndef BLESERVICE_HPP
#define BLESERVICE_HPP

#include <iostream>
#include <string>
#include <memory>
#include <gio/gio.h>
#include <vector>

#include "service/IService.hpp"
#include "websocket/GraphWebSocket.hpp"
#include "websocket/WSComm.hpp"

#include "BleFrameBuilder.hpp"
#include "CharRegistry.hpp"
#include "BleSimulation.hpp"
#include "BleDeviceManager.hpp"
#include "BleCharacteristicManager.hpp"
#include "BleDataProcessor.hpp"
#include "BlueZAdapter.hpp"
#include "EventLoopManager.hpp"


class BleService : public IService {
public:
    BleService();
    ~BleService() override;

    // IService interface
    bool start() override;
    void stop() override;
    bool isRunning() const override;
    bool configure(const std::string& jsonConfig) override;
    std::string sendCommand(const std::string& command) override;
    std::string getStatusJson() const override;

    // Device operations (delegated to BleDeviceManager)
    std::vector<BleDeviceInfo> scanDevices(int timeoutSeconds);
    bool connectToDevice(const std::string& mac);
    bool disconnectDevice(const std::string& mac);
    std::vector<BleServiceInfo> getServicesAndCharacteristics(const std::string& mac);
    bool removeDevice(const std::string& body);
    bool isConnected(const std::string& body);
    bool isPaired(const std::string& body);
    bool pairDevice(const std::string& body);
    bool cancelPairing(const std::string& body);
    bool trustDevice(const std::string& mac);
    std::vector<std::string> getConnectedDevices();
    bool cleanupDisconnectedDevices();

    // Characteristic operations (delegated to BleCharacteristicManager)
    std::string toggleNotify(const std::string& body);
    size_t readCharacteristics(const std::string& charPath, guint8* retData);
    std::string readService(const std::string& mac, const std::string& uuid);
    bool writeService(const std::string& body);
    bool enableServices(const std::string& mac);
    void printScanResults(const std::vector<BleDeviceInfo>& devices);

    // Graph operations (delegated to BleDataProcessor)
    void addGraphSocket(v_int32 userId, 
        const std::shared_ptr<oatpp::websocket::AsyncWebSocket>& socket,
        const std::shared_ptr<WSComm>& graphWebSocket);
    void leaveGraph(v_int32 userId);
    void streamGraph();
    bool isEmpty() const;

    // Simulation
    bool setSimulation(std::string body);
    bool webSocketMsgSetFps(std::string body);

private:
    // Manager instances for refactored services
    std::unique_ptr<EventLoopManager> m_loopManager;
    std::unique_ptr<BlueZAdapter> m_bluezAdapter;
    std::unique_ptr<BleDeviceManager> m_deviceManager;
    std::unique_ptr<BleCharacteristicManager> m_charManager;
    std::unique_ptr<BleDataProcessor> m_dataProcessor;

    // Utilities
    BleSimulation m_simulation;
    BleFrameBuilder m_frameBuilder;
    CharRegistry m_charRegistry;

    // State
    bool m_running = false;
    std::string m_macAddress;
    std::string m_lastCommandResponse;
    std::string m_adapterPath;

    // Initialization
    bool initBluez();
    void initializeManagers();
};

#endif // BLESERVICE_HPP